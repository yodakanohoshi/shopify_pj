# 任意: .env 経由でも設定を渡せる (.dlt/secrets.toml があればそちら優先で構わない)。
# このファイルを .env にコピーして利用する。
REST_BASE_URL=https://api.example.com/v1
REST_TOKEN_URL=https://api.example.com/oauth/token

# 方式A (推奨): Client ID / Secret (Client Credentials Grant)
REST_CLIENT_ID=your-client-id
REST_CLIENT_SECRET=your-client-secret
# REST_SCOPE=read:orders read:customers

# 方式B: 発行済みの固定トークンを使う場合はこちらのみ設定
# REST_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# dlt の出力先 DuckDB ファイル
REST_DUCKDB_PATH=rest_api.duckdb
