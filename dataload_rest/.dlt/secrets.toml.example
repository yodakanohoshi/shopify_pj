# このファイルを secrets.toml にコピーして値を埋める (secrets.toml は .gitignore 済み)。
[sources.rest_api]
# 方式A (推奨): Client ID / Secret。実行時に Client Credentials Grant で
#   アクセストークンを自動取得・更新する (token_url は config.toml で設定)。
client_id = "your-client-id"
client_secret = "your-client-secret"
# 任意: トークン要求時に送るスコープ
# scope = "read:orders read:customers"

# 方式B: 発行済みの固定トークンを使う場合はこちらのみ設定。
# access_token = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
