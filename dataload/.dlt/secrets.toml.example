# このファイルを secrets.toml にコピーして値を埋める (secrets.toml は .gitignore 済み)。
[sources.shopify]
# 方式A (推奨): Dev Dashboard アプリの Client ID / Secret。
#   実行時に Client Credentials Grant でアクセストークン (24h) を自動取得する。
client_id = "your-app-client-id"
client_secret = "your-app-client-secret"

# 方式B: App Automation Token など固定トークンを使う場合はこちらのみ設定。
# access_token = "shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
