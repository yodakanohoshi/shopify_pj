# 任意: .env 経由でも認証情報を渡せる (.dlt/secrets.toml があればそちら優先で構わない)。
# このファイルを .env にコピーして利用する。
SHOPIFY_SHOP=your-dev-store
SHOPIFY_API_VERSION=2025-01

# 方式A (推奨): Dev Dashboard アプリの Client ID / Secret (Client Credentials Grant)
SHOPIFY_CLIENT_ID=your-app-client-id
SHOPIFY_CLIENT_SECRET=your-app-client-secret

# 方式B: 固定トークン (App Automation Token 等) を使う場合はこちらのみ設定
# SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# dlt の出力先 DuckDB ファイル (elt/ の dbt と共有する物理パス)
SHOPIFY_DUCKDB_PATH=shopify.duckdb
